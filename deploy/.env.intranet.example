# ========================================
# ArtifactFlow Intranet Environment
# ========================================
# Copy to .env and fill in values before running deploy/docker-compose.intranet.yml
#
# Reload semantics — variables here fall into TWO categories with different
# reload paths. Picking the wrong one breaks silently.
#
#   ① ARTIFACTFLOW_*  (backend reads via env_file: .env — includes
#      JWT_SECRET / DATABASE_URL / REDIS_URL / MAX_CONCURRENT_TASKS / API keys)
#      → `docker compose -f deploy/docker-compose.intranet.yml up -d backend`
#        (`restart` does NOT re-read .env; `up -d` recreates the container)
#
#   ② POSTGRES_* (POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD)
#      → ⚠ init-only. postgres:16-alpine consumes these env vars ONLY when
#        $PGDATA is empty (fresh-init). On an already-init'd volume they
#        are IGNORED — recreating postgres does NOT change the DB-stored
#        password. Changing POSTGRES_PASSWORD + path ① will set backend's
#        DATABASE_URL to the new password while PG keeps the old → auth
#        fails silently (backend stuck unhealthy, PG looks healthy because
#        pg_isready doesn't authenticate).
#      → Correct password/user rotation: connect to PG and run
#          ALTER USER artifactflow WITH PASSWORD '<new>';
#        then update BOTH POSTGRES_PASSWORD here (kept in sync for future
#        fresh-init only) AND ARTIFACTFLOW_DATABASE_URL (the value backend
#        actually uses), then path ① to apply.
#      → Full rationale: docs/deployment.md → 滚动更新已有部署 →
#        "POSTGRES_* 不属于本流程"
#
# Editing ../config/* (not in this file) takes yet another path:
#   → `restart backend` (process re-reads MD/YAML on startup, no env change)
#
# All ARTIFACTFLOW_* variables are defined in src/config.py — see
# docs/deployment.md → 环境变量完整参考 for the full reference table.

# ============================================================================
# Required
# ============================================================================
ARTIFACTFLOW_JWT_SECRET=
ARTIFACTFLOW_REDIS_URL=redis://redis:6379
ARTIFACTFLOW_REDIS_KEY_PREFIX=af

# --- PostgreSQL (--profile infra) ---
# Set your password here, then copy it into DATABASE_URL below
POSTGRES_DB=artifactflow
POSTGRES_USER=artifactflow
POSTGRES_PASSWORD=CHANGE_ME
ARTIFACTFLOW_DATABASE_URL=postgresql+asyncpg://artifactflow:CHANGE_ME@postgres:5432/artifactflow
# NOTE: .env does not support variable references — password must match in both lines

# ============================================================================
# LLM API Keys (no ARTIFACTFLOW_ prefix — read by LiteLLM directly)
# ============================================================================
# Intranet LLM: edit config/models/models.yaml, set per-model base_url to internal inference endpoint
DASHSCOPE_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ============================================================================
# Tool API Keys
# ============================================================================
BOCHA_API_KEY=
# JINA_API_KEY=

# ============================================================================
# Intranet-specific overrides (commonly tuned)
# ============================================================================
# --- Concurrency (sized for 64-way model API parallelism) ---
# Defaults (10 / 50) underutilize a 64-concurrent model API — bumped to use the
# budget. If your model API has different concurrency, scale these proportionally
# (Redis pool ≈ 2×). Paired Redis maxmemory bump lives in deploy/docker-compose.intranet.yml.
ARTIFACTFLOW_MAX_CONCURRENT_TASKS=64          # default 10
ARTIFACTFLOW_REDIS_MAX_CONNECTIONS=128        # default 50

# DB pool: only safe for Mode 3A (--profile infra), where deploy/docker-compose.intranet.yml
# raises Postgres max_connections to 200. Mode 3B (internal/external DB, started
# without --profile infra) does NOT get that patch — if the internal DB has a low
# connection ceiling, POOL_SIZE+OVERFLOW=60 per backend can saturate it. Mode 3A
# users uncomment; Mode 3B users size to your DB's max_connections.
# ARTIFACTFLOW_DATABASE_POOL_SIZE=20          # default 5  (Mode 3A: uncomment)
# ARTIFACTFLOW_DATABASE_MAX_OVERFLOW=40       # default 10 (Mode 3A: uncomment)

# Internal LLM endpoints are often slower than cloud APIs — extend timeouts:
# ARTIFACTFLOW_EXECUTION_TIMEOUT=3600         # default 1800 (single turn ceiling, includes permission wait)
# ARTIFACTFLOW_COMPACTION_TIMEOUT=300         # default 120  (single compact LLM call timeout)
# ARTIFACTFLOW_PERMISSION_TIMEOUT=600         # default 300  (per-tool permission wait)

# If frontend is reached via a custom intranet hostname, add it to CORS:
# ARTIFACTFLOW_CORS_ORIGINS=["http://intranet.example.com","http://10.0.0.5"]

# Override host port if 80 is occupied (compose maps ${AF_HTTP_PORT:-80}:80):
# AF_HTTP_PORT=8080

# ============================================================================
# All tunables (uncomment to override defaults — see docs/deployment.md)
# ============================================================================

# --- Core ---
# ARTIFACTFLOW_DEBUG=false                    # verbose logs + un-redacted errors + Swagger enabled

# --- JWT ---
# ARTIFACTFLOW_JWT_ALGORITHM=HS256
# ARTIFACTFLOW_JWT_EXPIRY_DAYS=7

# --- Database pool ---
# ARTIFACTFLOW_DATABASE_URLS=                 # comma-separated multi-PX list, primary-first failover
# ARTIFACTFLOW_DATABASE_POOL_SIZE=5
# ARTIFACTFLOW_DATABASE_MAX_OVERFLOW=10
# ARTIFACTFLOW_DATABASE_POOL_TIMEOUT=30
# ARTIFACTFLOW_DATABASE_POOL_RECYCLE=300

# --- Redis ---
# ARTIFACTFLOW_REDIS_CLUSTER=false
# ARTIFACTFLOW_REDIS_MAX_CONNECTIONS=50
# ARTIFACTFLOW_LEASE_TTL=90                   # conversation lease TTL, heartbeat every TTL/3

# --- SSE / streaming ---
# ARTIFACTFLOW_SSE_PING_INTERVAL=15           # keepalive interval (s)
# ARTIFACTFLOW_STREAM_CLEANUP_TTL=60          # post-completion stream cleanup window (s)

# --- Compaction / context ---
# ARTIFACTFLOW_COMPACTION_TOKEN_THRESHOLD=80000  # in-engine compaction trigger (input+output tokens)
# ARTIFACTFLOW_INVENTORY_PREVIEW_LENGTH=200      # artifact inventory preview truncation

# --- CORS ---
# ARTIFACTFLOW_CORS_ALLOW_CREDENTIALS=true
# ARTIFACTFLOW_CORS_ALLOW_METHODS=["*"]
# ARTIFACTFLOW_CORS_ALLOW_HEADERS=["*"]

# --- Concurrency / limits ---
# ARTIFACTFLOW_MAX_CONCURRENT_TASKS=10        # max concurrent engine executions
# ARTIFACTFLOW_MAX_UPLOAD_SIZE=20971520       # bytes, default 20MB

# --- Pagination ---
# ARTIFACTFLOW_DEFAULT_PAGE_SIZE=20
# ARTIFACTFLOW_MAX_PAGE_SIZE=100
