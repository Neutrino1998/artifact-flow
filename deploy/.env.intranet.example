# ========================================
# ArtifactFlow Intranet Environment
# ========================================
# Copy to .env and fill in values before running deploy/docker-compose.intranet.yml

# --- Required ---
ARTIFACTFLOW_JWT_SECRET=
ARTIFACTFLOW_DATABASE_URL=postgresql+asyncpg://artifactflow:${POSTGRES_PASSWORD}@postgres:5432/artifactflow
ARTIFACTFLOW_REDIS_URL=redis://redis:6379
ARTIFACTFLOW_REDIS_KEY_PREFIX=af

# --- PostgreSQL container (--profile infra only) ---
POSTGRES_DB=artifactflow
POSTGRES_USER=artifactflow
POSTGRES_PASSWORD=             # CHANGE THIS

# --- LLM API Keys ---
# Intranet LLM: edit config/models/models.yaml, set per-model base_url to internal inference endpoint
DASHSCOPE_API_KEY=
# OPENAI_API_KEY=

# --- Tool API Keys ---
BOCHA_API_KEY=
# JINA_API_KEY=

# --- Optional ---
# ARTIFACTFLOW_DEBUG=true
