# ========================================
# 模型 API 配置
# ========================================

# ------ OpenAI (GPT系列) ------
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx
# 如果使用代理或第三方兼容服务，可以设置 base_url
# OPENAI_BASE_URL=https://api.openai.com/v1

# ------ 通义千问 (Qwen) ------
# 获取地址: https://dashscope.console.aliyun.com/apiKey
# 注意：这是 DashScope API Key，不是阿里云 AccessKey
DASHSCOPE_API_KEY=sk-xxx
# Qwen 的 base_url 已在代码中预设，无需配置

# ------ DeepSeek ------
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxx
# DeepSeek 的 base_url 已在代码中预设，无需配置

# ------ 自定义 OpenAI 兼容服务 ------
# 例如：LocalAI, FastChat, vLLM, Ollama 等
# CUSTOM_API_KEY=your-custom-key  # 如果需要
# CUSTOM_BASE_URL=http://localhost:8000/v1

# ========================================
# 工具 API 配置
# ========================================

# ------ 博查AI (Web搜索) ------
# 获取地址: https://open.bochaai.com
BOCHA_API_KEY=sk-xxx

# ------ Jina Reader API (网页抓取) ------
# 获取地址: https://jina.ai/reader
# 免费 tier 可用，设置后提升限额
# JINA_API_KEY=jina_xxx

# ========================================
# 应用配置（ARTIFACTFLOW_ 前缀）
# ========================================
# 以下配置项通过 Pydantic Settings 自动映射：
#   环境变量 ARTIFACTFLOW_XXX → config.XXX
# 完整配置项见 src/api/config.py

# JWT 密钥（必须设置，否则服务无法启动）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ARTIFACTFLOW_JWT_SECRET=your-secret-here

# 数据库连接（默认 SQLite，生产环境建议 PostgreSQL）
# ARTIFACTFLOW_DATABASE_URL=sqlite+aiosqlite:///data/artifactflow.db
# ARTIFACTFLOW_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/artifactflow

# Redis（可选，设置后启用跨 Worker 的 RuntimeStore + StreamTransport）
# 不设置则使用 InMemory 实现（单 Worker 模式）
# ARTIFACTFLOW_REDIS_URL=redis://localhost:6379

# 开启后输出 DEBUG 级别日志
# ARTIFACTFLOW_DEBUG=true
