# ========================================
# ArtifactFlow — Quick Trial (Mode 1)
# ========================================
# SQLite + InMemory RuntimeStore, no Redis required.
# For prod / intranet, see deploy/.env.prod.example or deploy/.env.intranet.example.

# ========================================
# LLM API Keys
# ========================================
DASHSCOPE_API_KEY=sk-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx

# ========================================
# Tool API Keys
# ========================================
BOCHA_API_KEY=sk-xxx
# JINA_API_KEY=jina_xxx

# ========================================
# App (ARTIFACTFLOW_ prefix; full reference: docs/deployment.md)
# ========================================
ARTIFACTFLOW_JWT_SECRET=       # python -c "import secrets; print(secrets.token_urlsafe(32))"
ARTIFACTFLOW_DATABASE_URL=sqlite+aiosqlite:///data/artifactflow.db
# ARTIFACTFLOW_DEBUG=true

# --- Common dev overrides (uncomment to use) ---
# ARTIFACTFLOW_EXECUTION_TIMEOUT=1800           # single turn ceiling (s)
# ARTIFACTFLOW_PERMISSION_TIMEOUT=300           # per-tool permission wait (s)
# ARTIFACTFLOW_COMPACTION_TOKEN_THRESHOLD=80000 # in-engine compaction trigger
# ARTIFACTFLOW_MAX_UPLOAD_SIZE=20971520         # bytes, default 20MB
# ARTIFACTFLOW_CORS_ORIGINS=["http://localhost:3000"]
